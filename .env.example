# Affirm项目 - 环境变量示例
# 复制此文件为 .env 并填写实际值

# ========================
# 数据库配置
# ========================
DB_URL=postgresql://username:password@localhost:5432/database_name
# Docker Compose 部署时使用（不再硬编码，需显式设置）
POSTGRES_PASSWORD=change_this_to_a_secure_password

# ========================
# Telegram配置
# ========================
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ========================
# Embedding配置（RAG语义检索）
# ========================
# 独立于主AI Provider，用于生成向量嵌入
# 推荐使用OpenAI兼容接口，DeepSeek无embedding端点
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your_openai_api_key_for_embedding
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
# 维度须与数据库 vector(768) 列保持一致，勿随意修改
EMBEDDING_DIMENSIONS=768

# ========================
# AI模型配置
# ========================
# 当前AI Provider（可选: deepseek 或 claude）
AI_PROVIDER=deepseek

# DeepSeek配置（优先使用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Claude配置（通过 AiGoCode OpenAI 兼容接口）
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=https://api.aigocode.com/v1
CLAUDE_MODEL=claude-sonnet-4-5-latest

# 兼容现有OpenAI配置（可选）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=${DEEPSEEK_BASE_URL}
MODEL_NAME=deepseek-reasoner

# ========================
# GitHub配置
# ========================
GITHUB_USERNAME=your_github_username
GITHUB_REPO=Affirm

# ========================
# OpenClaw配置
# ========================
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token

# ========================
# Notion配置 (Day 4使用)
# ========================
NOTION_TOKEN=your_notion_integration_token
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id

# ========================
# Redis配置（Phase 2 BullMQ队列）
# ========================
# Docker Compose 部署时 host 填服务名 redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password  # 无密码时注释掉
REDIS_URL=redis://localhost:6379

# ========================
# Webhook配置（Phase 2）
# ========================
# 开启 webhook 模式（false = polling, true = webhook）
WEBHOOK_ENABLED=false
# Telegram 回调 URL（公网 HTTPS 地址），需配置 Nginx + SSL
TELEGRAM_WEBHOOK_URL=https://your-domain.com
# Webhook 监听端口（Node.js 内部，Nginx 反向代理到此端口）
WEBHOOK_PORT=3002
# Webhook 鉴权 Token（随机字符串，Telegram 会在请求头中携带）
WEBHOOK_SECRET_TOKEN=change_this_to_a_random_secret

# ========================
# 项目配置
# ========================
TIMEZONE=Asia/Shanghai
LOG_LEVEL=info
NODE_ENV=development

# ========================
# 安全配置
# ========================
# 生产环境必须修改这些值
JWT_SECRET=change_this_to_a_secure_random_string
ENCRYPTION_KEY=change_this_to_another_secure_random_string

# ========================
# 可选配置
# ========================
# Telegram管理员ID（多个用逗号分隔）
TELEGRAM_ADMIN_IDS=123456789,987654321

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 数据库连接池配置
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000

# AI模型参数
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000
AI_TOP_P=0.9

# ========================
# 使用说明
# ========================
# 1. 复制此文件为 .env
#    cp .env.example .env
#
# 2. 编辑 .env 文件，填写实际值
#    nano .env
#
# 3. 确保 .env 在 .gitignore 中
#    （已默认配置）
#
# 4. 永远不要提交 .env 到版本控制！
#    （包含敏感信息）
# Notion集成配置
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_TEMPLATE_PAGE_ID=optional_template_page_id_here
