<div class="action-bar">
    <a href="/admin/knowledge/new" class="btn btn-primary">
        <i class="fas fa-plus"></i> 添加知识
    </a>
    <a href="/admin/knowledge/import" class="btn btn-secondary">
        <i class="fas fa-file-import"></i> 批量导入
    </a>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>User ID</th>
            <th>来源</th>
            <th>内容</th>
            <th>创建时间</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        <% if (knowledge && knowledge.length > 0) { %>
            <% knowledge.forEach(item => { %>
                <tr>
                    <td><%= item.id %></td>
                    <td><%= item.user_id || '-' %></td>
                    <td><%= item.source || '-' %></td>
                    <td><%= item.content ? item.content.slice(0, 80) : '-' %><%= item.content && item.content.length > 80 ? '...' : '' %></td>
                    <td><%= new Date(item.created_at).toLocaleString() %></td>
                    <td class="actions">
                        <a href="/admin/knowledge/<%= item.id %>/edit" class="btn btn-sm btn-edit">
                            <i class="fas fa-edit"></i> 编辑
                        </a>
                        <form action="/admin/knowledge/<%= item.id %>/delete" method="POST" style="display: inline;">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('确定删除此知识条目？')">
                                <i class="fas fa-trash"></i> 删除
                            </button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="6" class="text-center">暂无知识条目，<a href="/admin/knowledge/new">创建一个</a></td>
            </tr>
        <% } %>
    </tbody>
</table>
