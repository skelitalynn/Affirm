<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/static/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="container">
        <header class="header">
            <h1><i class="fas fa-cogs"></i> Affirm Admin</h1>
            <div class="user-info">
                <span><%= user ? user.name : 'admin' %> (<%= user ? user.role : 'admin' %>)</span>
                <a href="/admin/logout" class="btn btn-sm">Logout</a>
            </div>
        </header>

        <nav class="sidebar">
            <ul>
                <li><a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
                <li><a href="/admin/profiles"><i class="fas fa-users"></i> Profiles</a></li>
                <li><a class="active" href="/admin/knowledge"><i class="fas fa-brain"></i> Knowledge</a></li>
                <li><a href="/admin/settings"><i class="fas fa-sliders-h"></i> Settings</a></li>
            </ul>
        </nav>

        <main class="main">
            <h2>Knowledge</h2>

            <div class="action-bar" style="margin-bottom: 16px;">
                <a href="/admin/knowledge/new" class="btn btn-primary"><i class="fas fa-plus"></i> New Knowledge</a>
                <a href="/admin/knowledge/import" class="btn btn-secondary"><i class="fas fa-file-import"></i> Batch Import</a>
            </div>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User ID</th>
                        <th>Source</th>
                        <th>Content</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (knowledge && knowledge.length > 0) { %>
                        <% knowledge.forEach((item) => { %>
                            <tr>
                                <td><code><%= item.id %></code></td>
                                <td><code><%= item.user_id %></code></td>
                                <td><%= item.source || '-' %></td>
                                <td><%= item.content && item.content.length > 120 ? item.content.slice(0, 120) + '...' : (item.content || '-') %></td>
                                <td><%= item.created_at ? new Date(item.created_at).toLocaleString() : '-' %></td>
                                <td class="actions">
                                    <form action="/admin/knowledge/<%= item.id %>/delete" method="POST" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this knowledge item?')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="text-center">No knowledge records found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </main>

        <footer class="footer">
            <p>Affirm Admin v1.0.0 &copy; 2026</p>
        </footer>
    </div>

    <script src="/static/js/app.js"></script>
</body>
</html>
